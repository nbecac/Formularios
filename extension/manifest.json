{
  "manifest_version": 3,
  "name": "Formularios AI Assistant",
  "version": "1.0",
  "description": "Asistente local para rellenar formularios autorizados con IA. Nunca envía automáticamente.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Abrir asistente de formularios"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
